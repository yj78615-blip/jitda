// 짓다 (JITDA) — Prisma schema
// API 명세 §06 데이터 모델 기준. Phase 1 + Phase 2 필드 모두 포함.
// 마이그레이션: npm run db:migrate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")       // 앱 런타임 — Supabase pooled (6543)
  directUrl = env("DIRECT_URL")         // 마이그레이션 — direct (5432)
}

// ============================================================
//  Enums
// ============================================================

enum UserRole {
  USER
  CREATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_DELETION
  DELETED
}

enum OAuthProvider {
  GOOGLE
  APPLE
}

enum ViewerMode {
  SCROLL
  PAGE
}

enum SeriesStatus {
  ONGOING
  COMPLETED
  HIATUS
}

enum ContentTargetType {
  EPISODE
  POST
  COMMENT
  SALON
  USER
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  CANCELED
  PAST_DUE
  FAILED
}

enum TipStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum ReactionType {
  LIKE
  HEART
  FIRE
  SAD
  WOW
}

enum NotificationType {
  NEW_EPISODE
  NEW_COMMENT
  COMMENT_REPLY
  NEW_FOLLOWER
  NEW_SUBSCRIBER
  TIP_RECEIVED
  PAYMENT_FAILED
  PAYOUT_COMPLETED
  REPORT_RESOLVED
}

enum ReportCategory {
  COPYRIGHT
  ADULT
  VIOLENCE
  SPAM
  OTHER
}

enum ReportStatus {
  PENDING
  INVESTIGATING
  RESOLVED
  REJECTED
}

enum ReportAction {
  NONE
  TAKEDOWN
  STRIKE
  ACCOUNT_SUSPEND
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum ImageStatus {
  AWAITING_UPLOAD
  PROCESSING
  READY
  FAILED
}

enum RankingKind {
  SERIES
  POST
  AUTHOR
}

// ============================================================
//  Core: User & Auth
// ============================================================

model User {
  id                String       @id                           // usr_...
  email             String       @unique                       // 정규화된 소문자
  emailVerifiedAt   DateTime?
  passwordHash      String?                                    // Argon2id. OAuth-only 유저는 null.
  displayName       String
  handle            String       @unique                       // [a-z0-9_]{3,20}
  avatarImageId     String?
  bannerImageId     String?
  bio               String?      @db.Text
  externalLinks     Json?                                      // [{label, url}]
  role              UserRole     @default(USER)
  status            UserStatus   @default(ACTIVE)
  isAdultVerified   Boolean      @default(false)
  strikes           Int          @default(0)
  language          String       @default("ko")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?
  scheduledDeletionAt DateTime?

  // relations
  oauthAccounts     OAuthAccount[]
  refreshTokens     RefreshToken[]
  loginAttempts     LoginAttempt[]
  authorProfile     AuthorProfile?
  series            Series[]
  posts             Post[]
  images            Image[]
  followers         Follow[]        @relation("Followee")
  following         Follow[]        @relation("Follower")
  subscriptions     Subscription[]  @relation("Subscriber")
  subscribers       Subscription[]  @relation("SubAuthor")
  tipsSent          Tip[]           @relation("TipSender")
  tipsReceived      Tip[]           @relation("TipReceiver")
  comments          Comment[]
  reactions         Reaction[]
  notifications     Notification[]
  reportsAuthored   Report[]        @relation("ReportAuthor")
  reportsHandled    Report[]        @relation("ReportHandler")
  payouts           Payout[]
  notificationSettings NotificationSetting?

  @@index([status])
  @@index([createdAt])
}

model AuthorProfile {
  userId                String   @id
  subscriptionEnabled   Boolean  @default(false)
  subscriptionPrice     Int?                                  // KRW 원 단위 (1000-30000)
  subscriptionCurrency  String   @default("KRW")
  payoutAccountRef      String?                                // Stripe Connect account id
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OAuthAccount {
  id            String        @id @default(cuid())
  userId        String
  provider      OAuthProvider
  providerId    String                                        // provider가 제공한 sub
  emailAtLink   String
  createdAt     DateTime      @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
}

model RefreshToken {
  id            String    @id @default(cuid())
  userId        String
  tokenHash     String    @unique                              // 저장은 항상 해시
  parentId      String?                                        // 회전 chain
  userAgent     String?
  ip            String?
  issuedAt      DateTime  @default(now())
  expiresAt     DateTime
  revokedAt     DateTime?

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model LoginAttempt {
  id          String   @id @default(cuid())
  userId      String?                                          // 실패 시 null 가능
  emailTried  String                                           // 정규화된 소문자
  ip          String
  userAgent   String?
  success     Boolean
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([emailTried, ip, createdAt])
  @@index([ip, createdAt])
}

model EmailVerification {
  id          String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  consumedAt  DateTime?
}

model PasswordReset {
  id          String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  consumedAt  DateTime?
}

// ============================================================
//  Content: Series / Episode / Post / Image / Tag
// ============================================================

model Series {
  id                     String       @id                       // srs_...
  authorId               String
  title                  String
  description            String?      @db.Text
  coverImageId           String?
  viewerModeDefault      ViewerMode   @default(SCROLL)
  status                 SeriesStatus @default(ONGOING)
  isAdult                Boolean      @default(false)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  deletedAt              DateTime?

  // Denormalized aggregates. Episode view/like 발생 시 트랜잭션으로 함께 증가.
  viewsTotal             Int          @default(0)
  likesTotal             Int          @default(0)

  author                 User         @relation(fields: [authorId], references: [id])
  episodes               Episode[]
  tags                   SeriesTag[]

  @@index([authorId])
  @@index([status])
  @@index([updatedAt])
  @@index([viewsTotal])
}

model Episode {
  id                  String     @id                             // epi_...
  seriesId            String
  title               String
  order               Int
  viewerMode          ViewerMode
  isSubscriberOnly    Boolean    @default(false)
  isAdult             Boolean    @default(false)
  publishedAt         DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  deletedAt           DateTime?

  // 집계 (조회수는 별도 배치로 업데이트해도 되지만 hot-path 를 위해 로컬 카운트)
  viewsCount          Int        @default(0)
  likesCount          Int        @default(0)
  commentsCount       Int        @default(0)

  series              Series     @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  images              Image[]    @relation("EpisodeImages")

  @@unique([seriesId, order])
  @@index([publishedAt])
}

model Post {
  id                  String     @id                             // pst_...
  authorId            String
  title               String
  description         String?    @db.Text
  viewerMode          ViewerMode @default(SCROLL)
  isSubscriberOnly    Boolean    @default(false)
  isAdult             Boolean    @default(false)
  publishedAt         DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  deletedAt           DateTime?

  viewsCount          Int        @default(0)
  likesCount          Int        @default(0)
  commentsCount       Int        @default(0)

  author              User       @relation(fields: [authorId], references: [id])
  images              Image[]    @relation("PostImages")
  tags                PostTag[]

  @@index([authorId])
  @@index([publishedAt])
}

model Image {
  id            String      @id                                    // img_...
  ownerType     ContentTargetType?
  ownerId       String?
  uploaderId    String
  url           String?                                            // ready 이후 세팅
  status        ImageStatus @default(AWAITING_UPLOAD)
  width         Int?
  height        Int?
  fileSize      Int?
  contentType   String?
  purpose       String                                             // series_cover | episode_page | post_page | avatar | banner
  order         Int         @default(0)
  createdAt     DateTime    @default(now())

  uploader      User        @relation(fields: [uploaderId], references: [id])
  episode       Episode?    @relation("EpisodeImages", fields: [episodeId], references: [id], onDelete: SetNull)
  episodeId     String?
  post          Post?       @relation("PostImages", fields: [postId], references: [id], onDelete: SetNull)
  postId        String?

  @@index([uploaderId])
  @@index([status])
}

model Tag {
  id        String      @id @default(cuid())
  slug      String      @unique                                     // e.g. "romance", "일상"
  isGenre   Boolean     @default(false)
  nameKo    String
  nameEn    String

  seriesTags SeriesTag[]
  postTags   PostTag[]
}

model SeriesTag {
  seriesId  String
  tagId     String

  series    Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  tag       Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([seriesId, tagId])
  @@index([tagId])
}

model PostTag {
  postId  String
  tagId   String

  post    Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag     Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

// ============================================================
//  Social: Follow / Subscription / Tip / Comment / Reaction
// ============================================================

model Follow {
  followerId String
  authorId   String
  createdAt  DateTime @default(now())

  follower   User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  author     User @relation("Followee", fields: [authorId],   references: [id], onDelete: Cascade)

  @@id([followerId, authorId])
  @@index([authorId])
}

model Subscription {
  id                    String             @id                     // sub_...
  subscriberId          String
  authorId              String
  price                 Int                                         // KRW 원 단위
  currency              String             @default("KRW")
  status                SubscriptionStatus @default(PENDING)
  startedAt             DateTime           @default(now())
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  canceledAt            DateTime?
  failedAttempts        Int                @default(0)
  stripeSubscriptionId  String?            @unique
  stripeCustomerId      String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  subscriber            User               @relation("Subscriber",  fields: [subscriberId], references: [id])
  author                User               @relation("SubAuthor",   fields: [authorId],     references: [id])

  @@unique([subscriberId, authorId])
  @@index([authorId, status])
  @@index([currentPeriodEnd])
}

model Tip {
  id                     String    @id                              // tip_...
  senderId               String
  authorId               String
  amount                 Int
  currency               String    @default("KRW")
  message                String?   @db.Text
  messagePublic          Boolean   @default(false)
  status                 TipStatus @default(PENDING)
  contextType            ContentTargetType?
  contextId              String?
  stripePaymentIntentId  String?   @unique
  createdAt              DateTime  @default(now())

  sender                 User      @relation("TipSender",   fields: [senderId], references: [id])
  author                 User      @relation("TipReceiver", fields: [authorId], references: [id])

  @@index([authorId, createdAt])
  @@index([senderId, createdAt])
}

model Comment {
  id            String             @id                              // cmt_...
  targetType    ContentTargetType
  targetId      String
  parentId      String?
  authorId      String
  body          String             @db.Text
  isPinned      Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?

  author        User               @relation(fields: [authorId], references: [id])
  parent        Comment?           @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies       Comment[]          @relation("CommentReplies")
  reactions     Reaction[]

  @@index([targetType, targetId, createdAt])
  @@index([parentId])
}

model Reaction {
  id           String            @id @default(cuid())
  userId       String
  targetType   ContentTargetType
  targetId     String
  type         ReactionType
  createdAt    DateTime          @default(now())

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment      Comment?          @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId    String?

  @@unique([userId, targetType, targetId, type])
  @@index([targetType, targetId])
}

// ============================================================
//  Notifications
// ============================================================

model Notification {
  id          String           @id                                  // ntf_...
  userId      String
  type        NotificationType
  payload     Json
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model NotificationSetting {
  userId                     String  @id
  newEpisodeInApp            Boolean @default(true)
  newEpisodeEmail            String  @default("instant")             // instant | daily | weekly | off
  newCommentInApp            Boolean @default(true)
  newCommentEmail            String  @default("daily")
  newFollowerInApp           Boolean @default(true)
  newFollowerEmail           String  @default("off")
  tipReceivedInApp           Boolean @default(true)
  tipReceivedEmail           String  @default("instant")
  paymentFailedInApp         Boolean @default(true)
  paymentFailedEmail         String  @default("instant")
  updatedAt                  DateTime @updatedAt

  user                       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
//  Moderation
// ============================================================

model Report {
  id            String            @id                               // rep_...
  reporterId    String
  targetType    ContentTargetType
  targetId      String
  category      ReportCategory
  description   String            @db.Text
  status        ReportStatus      @default(PENDING)
  action        ReportAction?
  noteInternal  String?           @db.Text
  handledById   String?
  handledAt     DateTime?
  createdAt     DateTime          @default(now())

  reporter      User              @relation("ReportAuthor",  fields: [reporterId], references: [id])
  handledBy     User?             @relation("ReportHandler", fields: [handledById], references: [id])

  @@index([status, createdAt])
  @@index([category, status])
}

// ============================================================
//  Payouts
// ============================================================

model Payout {
  id             String       @id                                    // pyt_...
  authorId       String
  period         String                                               // "2026-06"
  gross          Int
  platformFee    Int
  stripeFee      Int
  refundReserve  Int
  net            Int
  currency       String       @default("KRW")
  status         PayoutStatus @default(PENDING)
  paidAt         DateTime?
  stripePayoutId String?      @unique
  createdAt      DateTime     @default(now())

  author         User         @relation(fields: [authorId], references: [id])

  @@unique([authorId, period])                                        // idempotency
  @@index([period])
}

// ============================================================
//  Ranking snapshots (배치 결과 저장)
// ============================================================

model RankingSnapshot {
  id           String      @id @default(cuid())
  kind         RankingKind
  targetId     String
  score        Float
  rank         Int
  period       String                                                 // "weekly:2026-W28" 등
  computedAt   DateTime    @default(now())

  @@unique([kind, period, targetId])
  @@index([kind, period, rank])
}

// ============================================================
//  Global settings (관리자 튜닝 변수 저장)
// ============================================================

model PlatformSetting {
  key         String   @id                                            // "platform_fee_pct" 등
  value       Json
  updatedAt   DateTime @updatedAt
  updatedById String?
}

// ============================================================
//  Audit log — append-only
//   프로덕션에서는 애플리케이션 유저에게 UPDATE/DELETE 권한 미부여.
// ============================================================

model AuditLog {
  id          String   @id @default(cuid())
  ts          DateTime @default(now())
  actorUserId String?
  ip          String?
  userAgent   String?
  action      String                                                  // "content.takedown" 등
  targetType  String?
  targetId    String?
  reason      String?
  requestId   String?
  outcome     String                                                  // "success" | "failure"
  metadata    Json?

  @@index([ts])
  @@index([actorUserId, ts])
  @@index([action, ts])
}

// ============================================================
//  Webhook 이벤트 idempotency
// ============================================================

model StripeEvent {
  id           String   @id                                           // Stripe event id (evt_...)
  type         String
  processedAt  DateTime @default(now())
  payload      Json

  @@index([type])
}

